# ─── A/H Premium Arbitrage Monitor — Environment Configuration ───
#
# Copy this file to .env and fill in your values.
# Lines starting with # are ignored. Uncomment to override defaults.

# ─── Secrets (required for Telegram alerts) ───
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Futu OpenD Gateway ───
# OPEND_HOST=127.0.0.1
# OPEND_PORT=11111

# ─── Database Directory ───
# Override the default ~/.ah-arb data directory
# AH_ARB_DB_DIR=/path/to/your/data/dir

# ─── China Proxy for A-share APIs (Sina/Tencent) ───
# Full proxy URL — leave unset to disable proxy
# A_SHARE_PROXY_URL=http://user:pass@host:port

# ─── Sync Thread Pool Sizes ───
# SYNC_A_WORKERS=10
# SYNC_H_WORKERS=4
